<view class="container">

  <!-- 光晕 -->
  <view class="glow glow-a"></view>
  <view class="glow glow-b"></view>

  <!-- 顶部头部 -->
  <view class="page-header" style="padding-top: {{statusBarHeight + 12}}px;">
    <text class="page-brand">INSPIRED WARDROBE</text>
    <text class="page-title">穿搭日历</text>
  </view>

  <scroll-view scroll-y class="content-scroll">

    <!-- 日历卡片 -->
    <view class="calendar-card">
      <view class="calendar-header">
        <view class="month-block">
          <text class="month-title">{{year}} · {{month}}</text>
          <text class="month-sub">{{month}}月份穿搭记录</text>
        </view>
        <view class="nav-arrows">
          <view class="arrow-btn" bindtap="prevMonth"><text class="arrow">‹</text></view>
          <view class="arrow-btn" bindtap="nextMonth"><text class="arrow">›</text></view>
        </view>
      </view>

      <view class="week-days">
        <text>日</text><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text>
      </view>

      <view class="days-grid">
        <view
          wx:for="{{days}}"
          wx:key="index"
          class="day {{item.prev ? 'prev-month' : ''}} {{item.hasRecord ? 'has-dot' : ''}} {{activeFullDate === item.fullDate ? 'active' : ''}}"
          bindtap="selectDate"
          data-date="{{item.date}}"
          data-fulldate="{{item.fullDate}}"
          data-prev="{{item.prev}}"
        >
          <view class="{{activeFullDate === item.fullDate ? 'active-bg' : 'day-inner'}}">{{item.date}}</view>
          <view class="dot" wx:if="{{item.hasRecord}}"></view>
        </view>
      </view>

      <!-- 当日穿搭 -->
      <view class="daily-section">
        <view class="daily-look" wx:if="{{currentDailyLook}}" bindtap="goToDetail">
          <image wx:if="{{currentDailyLook.preview_url}}" class="daily-img" src="{{currentDailyLook.preview_url}}" mode="aspectFill"></image>
          <view wx:else class="daily-img daily-img-empty">
            <text class="daily-emoji">🧥</text>
          </view>
          <view class="daily-info">
            <text class="daily-label">今日穿搭</text>
            <text class="daily-title">{{currentDailyLook.title || '今日搭配'}}</text>
            <text class="daily-hint">点击查看详情 ›</text>
          </view>
        </view>
        <view class="daily-empty" wx:else>
          <text class="daily-empty-icon">📅</text>
          <view class="daily-empty-copy">
            <text class="daily-empty-title">今天还没有记录穿搭</text>
            <text class="daily-empty-desc">去穿搭页面保存一套今日穿搭吧</text>
          </view>
          <button class="add-record-btn" size="mini" bindtap="goToRecord">去记录</button>
        </view>
      </view>
    </view>

    <!-- 灵感扭蛋机 -->
    <view class="gacha-header">
      <view class="gacha-header-left">
        <text class="gacha-kicker">RANDOM OUTFIT</text>
        <text class="gacha-title">灵感扭蛋机</text>
      </view>
      <text class="gacha-desc">不知道穿什么？来抽一套！</text>
    </view>

    <view class="gacha-card">
      <view class="slot-machine">
        <view class="slot-window" wx:if="{{allOutfits && allOutfits.length > 0}}">
          <view class="slot-reel {{isGenerating ? 'spinning-outfit' : 'transitioning'}}" style="transform: translateY(-{{isGenerating ? 0 : slotIndex * 200}}px)">
            <view class="slot-item" wx:for="{{slotItems}}" wx:key="index">
              <image class="slot-img" src="{{item.url}}" mode="aspectFill"></image>
            </view>
          </view>
        </view>
        <view class="slot-window slot-empty" wx:else>
          <text class="slot-empty-icon">🧥</text>
        </view>
      </view>

      <view class="gacha-name" wx:if="{{randomLook}}">
        <text class="gacha-name-text">{{randomLook.title}}</text>
      </view>
      <view class="gacha-name" wx:elif="{{!allOutfits || allOutfits.length === 0}}">
        <text class="gacha-tip">快去画布搭配属于你的第一套穿搭吧</text>
      </view>

      <view class="gacha-actions">
        <button class="gacha-btn primary-btn" bindtap="generateRandomLook">
          {{isGenerating ? '生成中...' : (randomLook ? '✨ 再次生成' : '✨ 随机生成穿搭')}}
        </button>
        <button class="gacha-btn share-btn" bindtap="shareWeiXin">
          <image class="share-icon" src="https://img.icons8.com/fluency-systems-filled/48/ffffff/weixing.png"></image>
          发送给好友
        </button>
      </view>
    </view>

    <view style="height: 24px;"></view>
  </scroll-view>

  <!-- Tab Bar -->
  <view class="tab-bar glass">
    <view class="tab-item" bindtap="switchTab" data-path="/pages/wardrobe/wardrobe">
      <image class="tab-icon" src="../images/tabbar/shirt.png"></image>
      <text class="tab-text">衣橱</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/canvas/canvas">
      <image class="tab-icon" src="../images/tabbar/fantasy.png"></image>
      <text class="tab-text">画布</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/looks/looks">
      <image class="tab-icon" src="../images/tabbar/hanger.png"></image>
      <text class="tab-text">穿搭</text>
    </view>
    <view class="tab-item active">
      <image class="tab-icon" src="../images/tabbar/calendar_active.png"></image>
      <text class="tab-text">日历</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/profile/profile">
      <image class="tab-icon" src="../images/tabbar/user.png"></image>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
