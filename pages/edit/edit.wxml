<view class="container">
  <view class="nav-header" style="padding-top: 47px; height: 87px;">
    <view class="nav-btn" bindtap="goBack">
      <text class="back-icon">‹</text> 取消
    </view>
    <view class="nav-title" style="top: 45px; height: 50px; line-height:50px;">编辑单品</view>
  </view>

  <view class="content">
    <!-- AI Cutout Result -->
    <view class="cutout-box">
      <!-- <text class="emoji-large">🧥</text> -->
      <image src="{{ currImage }}" mode="aspectFit" style="height:240px;width: 100%;"/>
      <view class="success-tag">
        <image class="tag-icon" src="https://img.icons8.com/ios-glyphs/30/8A2BE2/magic-wand.png"></image>
        <text>AI 抠图成功</text>
      </view>
    </view>
    <view class="reupload-btn" bindtap="reupload">
      <image class="reupload-icon" src="https://img.icons8.com/ios-glyphs/30/007AFF/refresh.png"></image>
      <text>重新上传</text>
    </view>

    <!-- Form -->
    <view class="form-group">
      <view class="form-row">
        <text class="label">单品名称</text>
        <input 
          class="value-input" 
          type="text" 
          placeholder="给这件衣服起个名字" 
          value="{{name}}" 
          bindinput="onNameInput"
          placeholder-class="value-input-placeholder"
        />
      </view>

      <view class="form-row" bindtap="selectCategory">
        <text class="label">分类</text>
        <view class="value-group">
          <text class="value">{{category}}</text>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="form-card">
        <view class="card-header">
          <text class="label">主色调</text>
          <text class="sub-label">(已自动提取)</text>
        </view>
        <view class="color-list">
          <view 
            wx:for="{{colors}}" 
            wx:key="index"
            class="color-item" 
            style="background-color: {{item.hex}}; border: {{activeColor === index ? '2px solid #8A2BE2' : '1px solid #EEEEEE'}};"
            bindtap="switchColor"
            data-index="{{index}}"
          ></view>
          <view class="color-item add-color" bindtap="addColor">
            <text>+</text>
          </view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-header">
          <text class="label">适合季节</text>
        </view>
        <view class="tag-list">
          <view 
            wx:for="{{seasons}}" 
            wx:key="index"
            class="tag-btn {{item.active ? 'active' : ''}}"
            bindtap="toggleSeason"
            data-index="{{index}}"
          >{{item.name}}</view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-header">
          <text class="label">穿着场合 (多选)</text>
        </view>
        <view class="tag-list">
          <view 
            wx:for="{{occasions}}" 
            wx:key="index"
            class="tag-btn {{item.active ? 'active' : ''}}"
            bindtap="toggleOccasion"
            data-index="{{index}}"
          >{{item.name}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义拾色器弹窗 -->
  <view wx:if="{{colorPickerVisible}}" class="picker-mask" catchtouchmove="stopTouchMove">
    <view class="picker-panel">
      <view class="picker-header">
        <text class="label">选择主色调</text>
      </view>

      <view class="picker-preview" style="background-color: {{tempColor}};"></view>
      <view class="picker-hex">当前颜色：{{tempColor}}</view>

      <!-- Canvas 调色盘：圆形展示 + 小圆圈标记当前颜色 -->
      <view class="color-wheel-wrapper">
        <canvas
          id="color-picker-canvas"
          canvas-id="colorPickerCanvas"
          class="color-canvas"
          disable-scroll="true"
          bindtouchstart="onColorCanvasTouch"
          bindtouchmove="onColorCanvasTouch"
        ></canvas>
        <view
          class="color-thumb"
          style="left: {{pickerX}}px; top: {{pickerY}}px; background-color: {{tempColor}};"
        ></view>
      </view>

      <view class="picker-actions">
        <button class="picker-btn cancel" bindtap="cancelColorPick">取消</button>
        <button class="picker-btn confirm" bindtap="confirmColorPick">确定</button>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="action-btn primary-btn" bindtap="saveItem">保存单品</button>
  </view>
</view>
