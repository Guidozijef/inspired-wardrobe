<view class="container">
  <view class="nav-header" style="padding-top: 47px; height: 87px;">
    <view class="nav-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
      <text>取消</text>
    </view>
    <view class="nav-title" style="top: 45px; height: 50px; line-height: 50px;">编辑单品</view>
  </view>

  <view class="content">
    <view class="cutout-box">
      <image wx:if="{{currImage}}" src="{{currImage}}" mode="aspectFit" style="height: 240px; width: 100%;" />
      <view class="success-tag" wx:if="{{hasCutout}}">
        <image class="tag-icon" src="https://img.icons8.com/ios-filled/30/8A2BE2/sparkling--v1.png"></image>
        <text>AI 抠图成功</text>
      </view>
    </view>

    <view class="reupload-btn" bindtap="reupload">
      <image class="reupload-icon" src="https://img.icons8.com/ios-glyphs/30/8A2BE2/refresh.png"></image>
      <text>重新上传</text>
    </view>

    <view class="form-group">
      <view class="form-row">
        <view class="label-with-icon">
          <view class="value-icon-badge">
            <image class="value-icon-image" src="/assets/icons/field-tag.svg" mode="aspectFit" />
          </view>
          <text class="label">单品名称</text>
        </view>
        <input
          class="value-input"
          type="text"
          placeholder="给这件衣服起个名字"
          value="{{name}}"
          bindinput="onNameInput"
          placeholder-class="value-input-placeholder"
        />
      </view>

      <view class="form-card">
        <view class="card-header">
          <view class="label-with-icon">
            <view class="value-icon-badge">
              <image class="value-icon-image" src="/assets/icons/field-grid.svg" mode="aspectFit" />
            </view>
            <text class="label">分类</text>
          </view>
        </view>
        <view class="tag-list">
          <view
            wx:for="{{categories}}"
            wx:key="index"
            class="tag-btn {{category === item.value ? 'active' : ''}}"
            bindtap="toggleTag"
            data-type="category"
            data-val="{{item.value}}"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-header">
          <view class="label-with-icon">
            <view class="value-icon-badge">
              <image class="value-icon-image" src="/assets/icons/field-palette.svg" mode="aspectFit" />
            </view>
            <text class="label">主色调</text>
          </view>
          <text class="sub-label">(AI自动识别)</text>
        </view>
        <view class="color-list">
          <view
            wx:for="{{colors}}"
            wx:key="index"
            class="color-item"
            style="background-color: {{item.hex}}; border: {{activeColor === index ? '2px solid #8A2BE2' : '1px solid #EEEEEE'}};"
            bindtap="switchColor"
            data-index="{{index}}"
          ></view>
          <view class="color-item add-color" bindtap="addColor">
            <text>+</text>
          </view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-header">
          <view class="label-with-icon">
            <view class="value-icon-badge">
              <image class="value-icon-image" src="/assets/icons/field-season.svg" mode="aspectFit" />
            </view>
            <text class="label">适合季节</text>
          </view>
        </view>
        <view class="tag-list">
          <view
            wx:for="{{seasons}}"
            wx:key="index"
            class="tag-btn {{item.active ? 'active' : ''}}"
            bindtap="toggleSeason"
            data-index="{{index}}"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-header">
          <view class="label-with-icon">
            <view class="value-icon-badge">
              <image class="value-icon-image" src="/assets/icons/field-calendar.svg" mode="aspectFit" />
            </view>
            <text class="label">穿着场合</text>
          </view>
          <text class="sub-label">(可多选)</text>
        </view>
        <view class="tag-list">
          <view
            wx:for="{{occasions}}"
            wx:key="index"
            class="tag-btn {{item.active ? 'active' : ''}}"
            bindtap="toggleOccasion"
            data-index="{{index}}"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="form-row">
        <view class="label-with-icon">
          <view class="value-icon-badge">
            <image class="value-icon-image" src="/assets/icons/field-yuan.svg" mode="aspectFit" />
          </view>
          <text class="label">价格</text>
        </view>
        <view class="value-with-icon">
          <input
            class="value-input"
            type="digit"
            placeholder="输入价格"
            value="{{price}}"
            bindinput="onPriceInput"
            placeholder-class="value-input-placeholder"
          />
        </view>
      </view>

      <view class="form-row">
        <view class="label-with-icon">
          <view class="value-icon-badge">
            <image class="value-icon-image" src="/assets/icons/field-note.svg" mode="aspectFit" />
          </view>
          <text class="label">备注</text>
        </view>
        <view class="value-with-icon">
          <input
            class="value-input"
            type="text"
            placeholder="添加备注"
            value="{{note}}"
            bindinput="onNoteInput"
            placeholder-class="value-input-placeholder"
          />
        </view>
      </view>

      <view class="more-fields" wx:if="{{showMore}}">
        <view class="form-card">
          <view class="card-header">
            <view class="label-with-icon">
              <view class="value-icon-badge">
                <image class="value-icon-image" src="/assets/icons/field-fabric.svg" mode="aspectFit" />
              </view>
              <text class="label">材质</text>
            </view>
          </view>
          <view class="tag-list">
            <view
              wx:for="{{materials}}"
              wx:key="index"
              class="tag-btn {{material === item.value ? 'active' : ''}}"
              bindtap="toggleTag"
              data-type="material"
              data-val="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-card">
          <view class="card-header">
            <view class="label-with-icon">
              <view class="value-icon-badge">
                <image class="value-icon-image" src="/assets/icons/field-pattern.svg" mode="aspectFit" />
              </view>
              <text class="label">花纹</text>
            </view>
          </view>
          <view class="tag-list">
            <view
              wx:for="{{patterns}}"
              wx:key="index"
              class="tag-btn {{pattern === item.value ? 'active' : ''}}"
              bindtap="toggleTag"
              data-type="pattern"
              data-val="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-card">
          <view class="card-header">
            <view class="label-with-icon">
              <view class="value-icon-badge">
                <image class="value-icon-image" src="/assets/icons/field-ruler.svg" mode="aspectFit" />
              </view>
              <text class="label">尺码</text>
            </view>
          </view>
          <view class="tag-list">
            <view
              wx:for="{{sizes}}"
              wx:key="index"
              class="tag-btn {{size === item.value ? 'active' : ''}}"
              bindtap="toggleTag"
              data-type="size"
              data-val="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-row">
          <view class="label-with-icon">
            <view class="value-icon-badge">
              <image class="value-icon-image" src="/assets/icons/field-brand.svg" mode="aspectFit" />
            </view>
            <text class="label">品牌</text>
          </view>
          <view class="value-with-icon">
            <input
              class="value-input"
              type="text"
              placeholder="输入品牌"
              value="{{brand}}"
              bindinput="onBrandInput"
              placeholder-class="value-input-placeholder"
            />
          </view>
        </view>
      </view>

      <view class="more-toggle" bindtap="toggleMore">
        <view class="more-toggle-content">
          <view class="more-toggle-text">{{showMore ? '收起更多信息' : '查看更多信息'}}</view>
          <view class="more-toggle-arrow {{showMore ? 'expanded' : ''}}"></view>
        </view>
      </view>

    </view>
  </view>

  <view wx:if="{{colorPickerVisible}}" class="picker-mask" catchtouchmove="stopTouchMove">
    <view class="picker-panel">
      <view class="picker-header">
        <view class="label-with-icon">
          <view class="value-icon-badge">
            <image class="value-icon-image" src="/assets/icons/field-picker.svg" mode="aspectFit" />
          </view>
          <text class="label">选择主色调</text>
        </view>
      </view>

      <view class="picker-preview" style="background-color: {{tempColor}};"></view>
      <view class="picker-hex">当前颜色：{{tempColor}}</view>

      <view class="color-wheel-wrapper">
        <canvas
          id="color-picker-canvas"
          canvas-id="colorPickerCanvas"
          class="color-canvas"
          disable-scroll="true"
          bindtouchstart="onColorCanvasTouch"
          bindtouchmove="onColorCanvasTouch"
        ></canvas>
        <view
          class="color-thumb"
          style="left: {{pickerX}}px; top: {{pickerY}}px; background-color: {{tempColor}};"
        ></view>
      </view>

      <view class="picker-actions">
        <button class="picker-btn cancel" bindtap="cancelColorPick">取消</button>
        <button class="picker-btn confirm" bindtap="confirmColorPick">确定</button>
      </view>
    </view>
  </view>

  <canvas type="2d" id="processCanvas" style="width: 1000px; height: 1000px; position: absolute; left: -9999px;"></canvas>

  <view class="bottom-bar">
    <button wx:if="{{editingId}}" class="action-btn delete-btn" bindtap="deleteItem">删除单品</button>
    <button class="action-btn primary-btn {{editingId ? 'half-width' : ''}}" bindtap="saveItem">
      {{editingId ? '保存修改' : '保存单品'}}
    </button>
  </view>

  <view wx:if="{{showLimitModal}}" class="limit-mask" catchtouchmove="stopTouchMove">
    <view class="limit-panel">
      <view class="limit-icon-wrap">
        <text class="limit-icon">✦</text>
      </view>
      <text class="limit-title">今日 AI 抠图额度已用完</text>
      <text class="limit-desc">AI 抠图每天有 10 次免费额度，明天 0 点会自动恢复。继续上传时会保留原图，不再进行 AI 抠图。</text>
      <view class="limit-divider"></view>
      <view class="limit-btn" bindtap="closeLimitModal">
        <text class="limit-btn-text">我知道了</text>
      </view>
    </view>
  </view>
</view>
