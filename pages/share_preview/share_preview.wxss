.container {
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top, rgba(168, 124, 255, 0.16), transparent 38%),
    linear-gradient(180deg, #fbfaff 0%, #f4f6fb 100%);
}

.content {
  height: 100vh;
  box-sizing: border-box;
  padding: 15px 18px 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.poster-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: flex-start;
  overflow-y: auto;
}

.poster-card {
  width: 100%;
  border-radius: 32px;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 3px 8px rgba(90, 70, 140, 0.12);
  padding: 16px;
  box-sizing: border-box;
  backdrop-filter: blur(20px);
}

.poster-preview {
  border-radius: 24px;
  background: #ffffff;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.preview-image-wrap {
  position: relative;
  background: linear-gradient(180deg, rgba(247, 245, 255, 0.95) 0%, rgba(236, 239, 247, 0.95) 100%);
}

.poster-image {
  width: 100%;
  display: block;
  position: relative;
  z-index: 1;
}

.poster-loading {
  width: 100%;
  min-height: 450px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f87a8;
  font-size: 15px;
}

.poster-overlay {
  position: absolute;
  z-index: 2;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18px 20px 22px;
  background: linear-gradient(180deg, rgba(17, 17, 17, 0) 0%, rgba(17, 17, 17, 0.44) 100%);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.poster-serial {
  color: rgba(255, 255, 255, 0.7);
  font-size: 11px;
  letter-spacing: 2px;
}

.poster-title {
  color: #ffffff;
  font-size: 22px;
  font-weight: 700;
}

.poster-subtitle {
  color: rgba(255, 255, 255, 0.86);
  font-size: 12px;
}

.poster-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 5px 18px;
  background: rgba(255, 255, 255, 0.98);
}

.poster-footer-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.poster-footer-title {
  color: #2c223d;
  font-size: 18px;
  font-weight: 700;
}

.poster-footer-desc {
  color: #8c86a3;
  font-size: 12px;
}

.poster-qr {
  width: 72px;
  height: 72px;
  border-radius: 16px;
  flex-shrink: 0;
}

.actions {
  flex: 0.25;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.action-row {
  display: flex;
  gap: 14px;
}

.action-btn {
  height: 56px;
  border-radius: 999px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  white-space: nowrap;
}

.btn-icon-img {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
}

.action-btn::after {
  border: none;
}

.primary-btn {
  color: #ffffff;
  width: 100%!important;
  background: linear-gradient(135deg, #8f43f6 0%, #a14dff 100%);
  box-shadow: 0 12px 24px rgba(143, 67, 246, 0.24);
}

.success-btn {
  flex: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #17c964 0%, #10b759 100%);
  box-shadow: 0 10px 20px rgba(23, 201, 100, 0.2);
}

.ghost-btn {
  flex: 1;
  color: #2f3440;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10px 20px rgba(66, 70, 80, 0.08);
}

.poster-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1080px;
  height: 1600px;
}
