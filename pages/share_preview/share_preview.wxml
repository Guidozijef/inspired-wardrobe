<view class="container">
  <view class="content">
    <view class="poster-shell">
      <view class="poster-card">
        <view class="poster-preview">
          <view class="preview-image-wrap" style="{{previewImageHeight ? 'height:' + previewImageHeight + 'px' : ''}}">
            <image
              wx:if="{{displayImage}}"
              class="poster-image {{imageLoaded ? 'image-visible' : ''}}"
              src="{{displayImage}}"
              mode="widthFix"
              bindload="onImageLoad"
            />
            <view wx:else class="poster-loading">{{emptyText}}</view>
            <view class="poster-overlay">
              <text class="poster-serial">{{serialText}}</text>
              <text class="poster-title">{{displayTitle}}</text>
              <text class="poster-subtitle">{{subtitleText}}</text>
            </view>
          </view>

          <view class="poster-footer">
            <view class="poster-footer-copy">
              <text class="poster-footer-title">{{appName}}</text>
              <text class="poster-footer-desc">{{appDesc}}</text>
            </view>
            <image class="poster-qr" src="/pages/images/qrX.jpg" mode="aspectFill"></image>
          </view>
        </view>
      </view>
    </view>

    <view class="actions">
      <button class="action-btn primary-btn" bindtap="savePoster">
        <image class="btn-icon-img" src="/assets/icons/btn-save.svg" mode="aspectFit"/>{{saveLabel}}
      </button>
      <view class="action-row">
        <button class="action-btn success-btn" open-type="share">
          <image class="btn-icon-img" src="/assets/icons/btn-friend.svg" mode="aspectFit"/>{{friendLabel}}
        </button>
        <button class="action-btn ghost-btn" bindtap="shareToMoments">
          <image class="btn-icon-img" src="/assets/icons/btn-moments.svg" mode="aspectFit"/>{{timelineLabel}}
        </button>
      </view>
    </view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>
</view>
