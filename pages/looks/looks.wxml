<view class="container">

  <!-- 光晕 -->
  <view class="glow glow-a"></view>
  <view class="glow glow-b"></view>

  <!-- 顶部头部 -->
  <view class="page-header" style="padding-top: {{statusBarHeight + 12}}px;">
    <text class="page-brand">MY WARDROBE</text>
    <text class="page-title">我的穿搭</text>
  </view>

  <scroll-view scroll-y class="content-scroll">
  <view class="content">
    <view class="looks-grid">
      <view class="look-card" wx:for="{{looks}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="look-img-wrapper" style="background-color: {{item.bg}};">
          <image wx:if="{{item.preview}}" class="look-preview" src="{{item.preview}}" mode="aspectFill" />
          <text wx:else class="emoji-huge">{{item.emoji}}</text>
        </view>
        <view class="look-info">
          <text class="look-title">{{item.title}}</text>
          <text class="look-date">{{item.date}}</text>
        </view>
      </view>
    </view>
    <view class="loading-status" wx:if="{{isLoading}}">加载中...</view>
    <view class="loading-status" wx:if="{{isNoMore && looks.length > 0}}">已经到底啦~</view>
    <view class="empty-state" wx:if="{{isNoMore && looks.length === 0}}">
      <text>还没有穿搭记录哦</text>
    </view>
  </view>
</scroll-view>

  <!-- Custom Tab Bar -->
  <view class="tab-bar glass">
    <view class="tab-item" bindtap="switchTab" data-path="/pages/wardrobe/wardrobe">
      <image class="tab-icon" src="../images/tabbar/shirt.png"></image>
      <text class="tab-text">衣橱</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/canvas/canvas">
      <image class="tab-icon" src="../images/tabbar/fantasy.png"></image>
      <text class="tab-text">画布</text>
    </view>
    <view class="tab-item active">
      <image class="tab-icon" src="../images/tabbar/hanger_active.png"></image>
      <text class="tab-text">穿搭</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/calendar/calendar">
      <image class="tab-icon" src="../images/tabbar/calendar.png"></image>
      <text class="tab-text">日历</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/profile/profile">
      <image class="tab-icon" src="../images/tabbar/user.png"></image>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
