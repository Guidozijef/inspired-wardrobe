<view class="container">
  <!-- <view class="nav-header glass" style="padding-top: {{statusBarHeight}}px; height: {{statusBarHeight + navBarHeight}}px;">
    <view class="nav-left-actions" style="position: absolute; z-index: 12; top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-btn" bindtap="goBack">
        <text class="back-icon">‹</text> 返回
      </view>
    </view>
    <view class="nav-title" style="height: {{navBarHeight}}px; line-height: {{navBarHeight}}px;">穿搭详情</view>
  </view> -->

  <view class="content">
    <view class="canvas-display" style="background-color: {{look.bg}};">
      <image wx:if="{{look.preview}}" class="full-preview" src="{{look.preview}}" mode="widthFix" />
      <text wx:else class="emoji-huge">{{look.emoji}}</text>
      <view class="watermark">VOGUE</view>
    </view>
    
    <view class="info-card">
      <view class="info-header">
        <text class="look-title">{{look.title}}</text>
        <text class="look-date">{{look.date}}</text>
      </view>
      <view class="divider"></view>
      <text class="section-title">包含单品</text>
      <view class="items-list">
        <view class="item-tag" wx:for="{{look.items}}" wx:key="index">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="delete-icon-btn" bindtap="deleteLook">
      <image class="btn-icon-only" src="https://img.icons8.com/ios-glyphs/30/ff4d4f/trash.png"></image>
      删除
    </button>
    <button class="action-btn share-btn" bindtap="shareImage">
      <image class="btn-icon" src="https://img.icons8.com/ios-glyphs/30/8A2BE2/share.png"></image>
      分享
    </button>
    <!-- <button class="action-btn primary-btn" bindtap="editLook">重新编辑</button> -->
  </view>
</view>
