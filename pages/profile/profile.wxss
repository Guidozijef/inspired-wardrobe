.container {
  min-height: 100vh;
  padding-bottom: 96px;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(138, 43, 226, 0.28), transparent 26%),
    radial-gradient(circle at left 28%, rgba(176, 96, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f5f0ff 0%, #f8f7fc 34%, #f4f7fb 100%);
}


.hero-shell {
  padding-left: 16px;
  padding-right: 16px;
  position: relative;
  z-index: 1;
}

.hero-card {
  padding: 18px 16px 14px;
  border-radius: 26px;
  background:
    linear-gradient(145deg, rgba(90, 41, 153, 0.94), rgba(146, 81, 231, 0.92));
  box-shadow:
    0 24px 48px rgba(97, 44, 170, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.18);
}

.hero-top {
  display: flex;
  align-items: center;
}

.avatar-ring {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  padding: 3px;
  background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(255,255,255,0.35));
  box-sizing: border-box;
  margin-right: 12px;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-text {
  display: flex;
  flex-direction: column;
}

.hero-kicker {
  font-size: 9px;
  letter-spacing: 1.5px;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 4px;
}

.user-name {
  font-size: 22px;
  line-height: 1.15;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-desc {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.74);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-id {
  margin-top: 8px;
  align-self: flex-start;
  padding: 3px 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.78);
  font-size: 10px;
  font-family: monospace;
  max-width: 160px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 160px;
}

.stats-card {
  margin-top: 14px;
  padding: 12px 8px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 16px;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 3px;
}

.stats-label {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.66);
  white-space: nowrap;
}

.stats-divider {
  width: 1px;
  height: 28px;
  background: rgba(255, 255, 255, 0.16);
}

.content-scroll {
  position: relative;
  z-index: 1;
  padding: 14px 16px 0;
}

.menu-panel {
  border-radius: 24px;
  padding: 14px;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(18px);
  box-shadow:
    0 18px 40px rgba(62, 32, 110, 0.08),
    inset 0 1px 0 rgba(255,255,255,0.72);
}

.panel-head {
  margin-bottom: 10px;
}

.panel-title {
  display: block;
  font-size: 18px;
  font-weight: 700;
  color: #26153d;
  margin-bottom: 2px;
  white-space: nowrap;
}

.panel-subtitle {
  display: block;
  font-size: 12px;
  color: #7b7392;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-list {
  border-radius: 20px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.8);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.76);
}

.menu-item {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 13px 14px;
  background: rgba(255, 255, 255, 0.9);
  border-bottom: 1px solid rgba(122, 104, 156, 0.08);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.menu-icon-wrap {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
  background: linear-gradient(180deg, rgba(242, 232, 255, 0.92), rgba(250, 247, 255, 0.8));
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9);
}

.menu-icon {
  width: 18px;
  height: 18px;
}

.menu-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.menu-text {
  font-size: 14px;
  color: #241538;
  font-weight: 600;
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-desc {
  font-size: 11px;
  color: #8c829d;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-arrow {
  margin-left: 10px;
  color: #b5acc7;
  font-size: 18px;
  line-height: 1;
}

.feedback-item {
  position: relative;
}

.feedback-overlay {
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100%;
  opacity: 0;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
}

.feedback-overlay::after {
  border: none;
}

.glass {
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(18px);
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 76px;
  display: flex;
  justify-content: space-around;
  padding-top: 10px;
  border-top: 1px solid rgba(189, 180, 208, 0.3);
  z-index: 50;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icon {
  width: 24px;
  height: 24px;
  margin-bottom: 4px;
}

.tab-text {
  font-size: 10px;
  color: #999999;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #8A2BE2;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  backdrop-filter: blur(4px);
}

.edit-modal-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  visibility: hidden;
}

.edit-modal-wrapper.modal-active {
  transform: translateY(0);
  visibility: visible;
}

.edit-modal {
  background: #ffffff;
  border-top-left-radius: 28px;
  border-top-right-radius: 28px;
  padding: 32px 24px;
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
  box-shadow: 0 -12px 40px rgba(0,0,0,0.1);
}

.modal-handle {
  width: 40px;
  height: 5px;
  background: #E2E8F0;
  border-radius: 3px;
  margin: -16px auto 28px;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28px;
}

.modal-title {
  font-size: 19px;
  font-weight: bold;
  color: #1E293B;
}

.modal-close {
  color: #94A3B8;
  padding: 8px;
  font-size: 20px;
  line-height: 1;
}

.edit-section {
  margin-bottom: 28px;
}

.edit-label {
  font-size: 14px;
  color: #64748B;
  margin-bottom: 14px;
  font-weight: 500;
  text-align: center;
}

.avatar-wrapper {
  background: transparent !important;
  padding: 0;
  width: 100px !important;
  height: 100px !important;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  display: block;
  margin: 0 auto;
  border: 4px solid #F1F5F9;
}

.avatar-wrapper::after {
  border: none !important;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-edit-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 11px;
  padding: 4px 0;
  text-align: center;
}

.nickname-input {
  background: #F1F5F9;
  height: 52px;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 16px;
  color: #1E293B;
  width: 100%;
  box-sizing: border-box;
}

.save-profile-btn {
  background: linear-gradient(135deg, #8A2BE2, #9370DB);
  color: #ffffff;
  border-radius: 12px;
  height: 54px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  margin-top: 32px;
  box-shadow: 0 8px 20px rgba(138, 43, 226, 0.25);
  font-size: 16px;
  border: none;
  width: 100% !important;
}

.save-profile-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
