/* ── Container ─────────────────────────────────────── */
.container {
  padding-bottom: 100px;
  min-height: 100vh;
  position: relative;
  background: linear-gradient(180deg, #faf8ff 0%, #f3f0fc 100%);
}

/* ── Sticky Header Area ─────────────────────────────── */
.sticky-area {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: rgba(250, 248, 255, 0.94);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid rgba(124, 58, 237, 0.06);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 20px 14px;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.header-brand {
  font-size: 11px;
  font-weight: 600;
  color: #7C3AED;
  letter-spacing: 2.5px;
  opacity: 0.72;
  margin-bottom: 3px;
}

.title {
  font-size: 30px;
  font-weight: 800;
  color: #3D1F8C;
  letter-spacing: 0.4px;
  line-height: 1.1;
}

.search-btn {
  width: 40px;
  height: 40px;
  background: #ffffff;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 14px rgba(100, 60, 200, 0.13);
}

.icon { width: 18px; height: 18px; }

/* ── Category Tabs ──────────────────────────────────── */
.categories {
  white-space: nowrap;
  padding: 4px 20px 8px;
  height: 54px;
  box-sizing: border-box;
}

.category-item {
  display: inline-block;
  padding: 5px 18px;
  color: #6B7280;
  font-size: 14px;
  font-weight: 500;
  border-radius: 20px;
  margin-right: 10px;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(124, 58, 237, 0.14);
}

.category-item.active {
  background: linear-gradient(135deg, #7C3AED 0%, #9F5FF0 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4px 14px rgba(124, 58, 237, 0.30);
}

/* ── Grid ───────────────────────────────────────────── */
.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 12px 16px;
  justify-content: space-between;
}

.grid-item {
  width: 48.5%;
  background: #ffffff;
  border-radius: 20px;
  padding: 10px;
  margin-bottom: 16px;
  box-shadow: 0 4px 20px rgba(100, 60, 200, 0.08);
  border: 1px solid rgba(124, 58, 237, 0.06);
  box-sizing: border-box;
}

@keyframes skeletonPulseWardrobe {
  0% { opacity: 0.7; }
  50% { opacity: 1; }
  100% { opacity: 0.7; }
}

.item-img-bg {
  background: linear-gradient(145deg, #f5f0ff 0%, #e9e2f9 100%);
  height: 175px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.main-img {
  width: 100%;
  height: 100%;
  padding: 6px;
  box-sizing: border-box;
}

.pre-load { opacity: 0; }
.fade-in { animation: trueFadeIn 0.5s ease-out forwards; }
@keyframes trueFadeIn {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}

.item-info { padding: 10px 4px 2px; }

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-title {
  font-size: 14px;
  font-weight: 700;
  color: #1C1033;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.season-list { display: flex; gap: 2px; margin-left: 4px; padding-top: 1px; }
.season-icon { font-size: 12px; opacity: 0.85; }

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
}

.item-desc {
  font-size: 12px;
  color: #9CA3AF;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  background: linear-gradient(135deg, #7C3AED, #9F5FF0);
  padding: 2px 8px;
  border-radius: 8px;
  font-size: 10px;
  color: #ffffff;
  font-weight: 600;
  margin-left: 6px;
  white-space: nowrap;
}

.loading-status {
  text-align: center;
  padding: 24px 0;
  color: #9CA3AF;
  font-size: 13px;
  width: 100%;
  letter-spacing: 0.3px;
}

/* ── Empty State ────────────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 80px;
  padding-bottom: 40px;
}

.empty-img { width: 180px; height: 180px; opacity: 0.8; }

.empty-title {
  font-size: 20px;
  font-weight: 700;
  color: #1C1033;
  margin-top: 24px;
  letter-spacing: 0.5px;
}

.empty-tips {
  font-size: 14px;
  color: #9CA3AF;
  margin-top: 10px;
  text-align: center;
  padding: 0 48px;
  line-height: 1.7;
}

.empty-btn {
  margin-top: 32px;
  background: linear-gradient(135deg, #7C3AED 0%, #9F5FF0 100%);
  color: #ffffff;
  padding: 12px 36px;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  box-shadow: 0 8px 24px rgba(124, 58, 237, 0.30);
  letter-spacing: 0.3px;
}

/* ── Floating Add Button ────────────────────────────── */
.add-btn {
  position: fixed;
  bottom: 100px;
  right: 20px;
  width: 52px;
  height: 52px;
  background: linear-gradient(135deg, #7C3AED 0%, #9F5FF0 100%);
  border-radius: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(124, 58, 237, 0.38);
  z-index: 40;
}

.add-icon {
  color: #ffffff;
  font-size: 28px;
  font-weight: 300;
  line-height: 52px;
}

/* ── Action Sheet ───────────────────────────────────── */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(15, 5, 35, 0.50);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.overlay.active { opacity: 1; pointer-events: auto; }

.action-sheet {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 16px 16px calc(16px + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.action-sheet.active { transform: translateY(0); }

.action-menu {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20px;
  margin-bottom: 12px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(100, 60, 200, 0.14);
}

.action-header {
  text-align: center;
  font-size: 12px;
  color: #9CA3AF;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  letter-spacing: 0.3px;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px;
  font-size: 17px;
  color: #7C3AED;
  font-weight: 500;
}

.border-b { border-bottom: 1px solid rgba(0, 0, 0, 0.04); }
.action-icon { width: 22px; height: 22px; margin-right: 10px; }

.action-cancel {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20px;
  padding: 18px;
  text-align: center;
  font-size: 17px;
  color: #7C3AED;
  font-weight: 700;
  box-shadow: 0 8px 32px rgba(100, 60, 200, 0.10);
}

/* ── Tab Bar ────────────────────────────────────────── */
.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 80px;
  display: flex;
  justify-content: space-around;
  padding-top: 12px;
  border-top: 1px solid rgba(124, 58, 237, 0.08);
  z-index: 50;
}

.glass {
  background: rgba(255, 255, 255, 0.90);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.tab-item { display: flex; flex-direction: column; align-items: center; }
.tab-icon { width: 24px; height: 24px; margin-bottom: 4px; }
.tab-text { font-size: 10px; color: #9CA3AF; font-weight: 500; }
.tab-item.active .tab-text { color: #7C3AED; }
