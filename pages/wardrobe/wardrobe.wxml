<view class="container">
  <!-- Sticky Top Section -->
  <view class="sticky-area">
    <!-- Header -->
    <view class="header" style="padding-top: {{statusBarHeight + 40}}px; padding-bottom: 10px;">
      <text class="title">我的衣橱</text>
      <view class="search-btn" bindtap="goToSearch">
        <image class="icon" src="https://img.icons8.com/ios-glyphs/30/666666/search--v1.png"></image>
      </view>
    </view>

    <!-- Categories -->
    <scroll-view class="categories" scroll-x="true">
      <view 
        wx:for="{{categories}}" 
        wx:key="index"
        class="category-item {{activeCategory === index ? 'active' : ''}}"
        bindtap="switchCategory"
        data-index="{{index}}"
      >{{item}}</view>
    </scroll-view>
  </view>

  <!-- Grid / Empty State -->
  <view class="grid" wx:if="{{items.length > 0}}">
    <view class="grid-item" wx:for="{{items}}" wx:key="index" bindtap="goToEdit" data-item="{{item}}">
      <view class="item-img-bg">
        <image class="main-img" src="{{item.emoji}}" mode="aspectFit" />
      </view>
      <view class="item-info">
        <view class="item-header">
          <view class="item-title">{{item.title}}</view>
          <view class="season-list">
            <text wx:for="{{item.seasons}}" wx:for-item="icon" wx:key="*this" class="season-icon">{{icon}}</text>
          </view>
        </view>
        <view class="item-bottom">
          <view class="item-desc">{{item.desc}}</view>
          <view class="tag" wx:if="{{item.tag}}">{{item.tag}}</view>
        </view>
      </view>
    </view>
    <view class="loading-status" wx:if="{{isLoading}}">加载中...</view>
    <view class="loading-status" wx:if="{{isNoMore && items.length > 0}}">到底啦，快去添加新单品吧~</view>
  </view>

  <!-- Empty State -->
  <view class="empty-state" wx:else>
    <image class="empty-img" src="./empty-state.png" mode="aspectFit"></image>
    <text class="empty-title">灵感尚未着色</text>
    <text class="empty-tips">这个分类下还没有单品，快去添加吧</text>
    <view class="empty-btn" bindtap="showActionSheet">立即添加</view>
  </view>

  <!-- Floating Add Button -->
  <view class="add-btn" bindtap="showActionSheet">
    <text class="add-icon">+</text>
  </view>

  <!-- Action Sheet Overlay -->
  <view class="overlay {{showAction ? 'active' : ''}}" bindtap="hideActionSheet">
    <view class="action-sheet {{showAction ? 'active' : ''}}" catchtap="stopProp">
      <view class="action-menu">
        <view class="action-header">添加新单品，AI 将自动去除背景</view>
        <view class="action-item border-b" bindtap="goPhotograph">
          <image class="action-icon" src="https://img.icons8.com/ios-glyphs/30/007AFF/camera.png"></image>
          <text>拍照</text>
        </view>
        <view class="action-item" bindtap="goPhotoalbum">
          <image class="action-icon" src="https://img.icons8.com/ios-glyphs/30/007AFF/image.png"></image>
          <text>从相册选择</text>
        </view>
      </view>
      <view class="action-cancel" bindtap="hideActionSheet">取消</view>
    </view>
  </view>

  <!-- Custom Tab Bar -->
  <view class="tab-bar glass">
    <view class="tab-item active">
      <image class="tab-icon" src="https://img.icons8.com/ios-glyphs/50/8A2BE2/shirt.png"></image>
      <text class="tab-text">衣橱</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/canvas/canvas">
      <image class="tab-icon" src="https://img.icons8.com/glyph-neue/50/999999/fantasy--v1.png"></image>
      <text class="tab-text">画布</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/looks/looks">
      <image class="tab-icon" src="https://img.icons8.com/ios-glyphs/50/999999/hanger.png"></image>
      <text class="tab-text">穿搭</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/calendar/calendar">
      <image class="tab-icon" src="https://img.icons8.com/ios-glyphs/50/999999/calendar.png"></image>
      <text class="tab-text">日历</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/profile/profile">
      <image class="tab-icon" src="https://img.icons8.com/ios-glyphs/50/999999/user.png"></image>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
