<view class="container">
  <view class="nav-header glass" style="padding-top: {{statusBarHeight}}px; height: {{statusBarHeight + navBarHeight}}px;">
    <view class="nav-left-actions" style="position: relative; z-index: 12;">
      <view class="nav-btn" bindtap="clearCanvas">清空</view>
      <view class="nav-btn primary" bindtap="saveCanvas">保存</view>
    </view>
    <view class="nav-title" style="top: {{statusBarHeight}}px; height: {{navBarHeight}}px; line-height: {{navBarHeight}}px;">搭配画布</view>
  </view>

  <!-- Movable Area for Drag and Drop -->
  <movable-area class="canvas-area">
    <view class="watermark">VOGUE</view>
    
    <movable-view 
      wx:for="{{canvasItems}}" 
      wx:key="id"
      class="canvas-item {{item.active ? '' : 'no-border'}}" 
      x="{{item.x}}" 
      y="{{item.y}}" 
      direction="{{item.active ? 'all' : 'none'}}" 
      damping="40"
      friction="2"
      scale="true"
      min-scale="0.5"
      max-scale="4"
      scale-value="{{item.scale || 1}}"
      bindtap="activateItem"
      catchtouchstart="{{item.active ? '' : 'activateItem'}}"
      bindchange="onItemChange"
      bindscale="onItemScale"
      data-id="{{item.id}}"
      style="z-index: {{item.zIndex || 1}};"
    >
      <image class="canvas-img" src="{{item.url}}" mode="aspectFit" />
      <view class="rotate-btn" wx:if="{{item.active}}" catchtap="removeItem" data-id="{{item.id}}">
        <text style="color: white; font-size: 12px;">×</text>
      </view>
    </movable-view>
  </movable-area>
  
  <!-- Hidden Canvas for Rendering -->
  <canvas type="2d" id="helperCanvas" style="width: {{helperCanvasWidth}}px; height: {{helperCanvasHeight}}px; position: absolute; left: -9999px;"></canvas>

  <view class="bottom-drawer">
    <view class="drawer-handle"></view>
    <view class="drawer-tabs">
      <view 
        wx:for="{{tabs}}" 
        wx:key="index"
        class="drawer-tab {{activeTab === index ? 'active' : ''}}"
        bindtap="switchDrawerTab"
        data-index="{{index}}"
      >{{item}}</view>
    </view>
    
    <!-- Library Categories -->
    <scroll-view class="library-categories" scroll-x="true" show-scrollbar="false" wx:if="{{activeTab === 0}}">
      <view 
        wx:for="{{categories}}" 
        wx:key="index"
        class="lib-cat-item {{activeCategory === index ? 'active' : ''}}"
        bindtap="switchCategory"
        data-index="{{index}}"
      >{{item}}</view>
    </scroll-view>
    
    <scroll-view class="item-scroll" scroll-x="true" scroll-with-animation="true" enhanced="true" show-scrollbar="false" wx:if="{{activeTab === 0}}">
      <view class="scroll-item" wx:for="{{libraryItems}}" wx:key="index" bindtap="addToCanvas" data-item="{{item}}">
        <image class="library-img" src="{{item.image_url}}" mode="aspectFit" />
      </view>
    </scroll-view>
    
    <view class="empty-state" wx:if="{{activeTab !== 0}}">
      <text>功能开发中...</text>
    </view>

    <view class="drag-hint" wx:if="{{activeTab === 0}}">
      <text class="arrow-up">↑</text> 点击单品放入画布
    </view>
  </view>

  <!-- Custom Tab Bar -->
  <view class="tab-bar glass">
    <view class="tab-item" bindtap="switchTab" data-path="/pages/wardrobe/wardrobe">
      <image class="tab-icon" src="../images/tabbar/shirt.png"></image>
      <text class="tab-text">衣橱</text>
    </view>
    <view class="tab-item active">
      <image class="tab-icon" src="../images/tabbar/fantasy_active.png"></image>
      <text class="tab-text">画布</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/looks/looks">
      <image class="tab-icon" src="../images/tabbar/hanger.png"></image>
      <text class="tab-text">穿搭</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/calendar/calendar">
      <image class="tab-icon" src="../images/tabbar/calendar.png"></image>
      <text class="tab-text">日历</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-path="/pages/profile/profile">
      <image class="tab-icon" src="../images/tabbar/user.png"></image>
      <text class="tab-text">我的</text>
    </view>
  </view>

  <!-- Save Definition Modal -->
  <view class="modal-mask {{showSaveModal ? 'show' : ''}}" bindtap="closeSaveModal">
    <view class="modal-content glass" catchtap="stopBubble">
      <view class="modal-header">
        <text class="modal-title">命名你的穿搭</text>
      </view>
      <view class="modal-body">
        <input 
          class="title-input" 
          placeholder="给这套穿搭起个名字..." 
          value="{{outfitTitle}}" 
          bindinput="onTitleInput"
          focus="{{showSaveModal}}"
        />
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closeSaveModal">取消</view>
        <view class="modal-btn confirm" bindtap="confirmSave">确定完成</view>
      </view>
    </view>
  </view>
</view>
