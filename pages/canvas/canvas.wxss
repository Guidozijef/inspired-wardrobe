.container { height: 100vh; display: flex; flex-direction: column; background-color: #ffffff; position: relative; }
.nav-header { display: flex; justify-content: space-between; align-items: center; padding: 0 20px; box-sizing: border-box; position: absolute; top: 0; left: 0; right: 0; z-index: 10; }
.glass { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); }
.nav-btn { color: #333333; font-size: 15px; font-weight: 500; position: relative; z-index: 12; padding: 4px 0; }
.nav-btn.primary { color: #8A2BE2; font-weight: bold; }
.nav-title { font-size: 16px; font-weight: bold; position: absolute; left: 0; right: 0; text-align: center; z-index: 11; pointer-events: none; }

.canvas-area { width: 100%; flex: 1; background-color: #F8FAFC; background-size: 20px 20px; background-image: radial-gradient(#D1D5DB 1px, transparent 1px); position: relative; overflow: hidden; }
.watermark { position: absolute; top: 100px; left: 20px; font-size: 40px; font-family: serif; color: #E2E8F0; font-weight: bold; letter-spacing: 8px; pointer-events: none; }

.canvas-item { width: 180px; height: 180px; display: flex; align-items: center; justify-content: center; position: relative; }
.item-rotator { box-sizing: border-box; border: 2px dashed transparent; border-radius: 8px; transition: border-color 0.2s; }
.item-rotator.active { border-color: #8A2BE2; }
.canvas-img { width: 100%; height: 100%; display: block; }
.delete-btn { position: absolute; top: -14px; right: -14px; width: 28px; height: 28px; background-color: #FF3B30; border-radius: 14px; display: flex; align-items: center; justify-content: center; z-index: 100; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
.rotate-handle { position: absolute; bottom: -14px; right: -14px; width: 28px; height: 28px; background-color: #8A2BE2; border-radius: 14px; display: flex; align-items: center; justify-content: center; z-index: 100; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }

.nav-left-actions { display: flex; gap: 16px; align-items: center; position: relative; z-index: 12; }

.bottom-drawer { height: 300px; background-color: #ffffff; border-radius: 24px 24px 0 0; box-shadow: 0 -10px 30px rgba(0,0,0,0.05); border-top: 1px solid #F1F5F9; display: flex; flex-direction: column; position: relative; z-index: 20; padding-bottom: 80px; }
.drawer-handle { width: 40px; height: 4px; background-color: #E2E8F0; border-radius: 2px; margin: 10px auto 10px; }
.drawer-tabs { display: flex; justify-content: space-around; padding: 0 16px 4px; border-bottom: 1px solid #F1F5F9; font-size: 14px; font-weight: bold; color: #94A3B8; }
.drawer-tab { padding-bottom: 8px; transition: all 0.3s; }
.drawer-tab.active { color: #8A2BE2; border-bottom: 2px solid #8A2BE2; }

.library-categories { white-space: nowrap; padding: 12px 16px 4px; box-sizing: border-box; }
.lib-cat-item { display: inline-block; padding: 4px 12px; background-color: #F2F2F7; border-radius: 10px; margin-right: 8px; font-size: 12px; color: #666666; transition: all 0.2s; }
.lib-cat-item.active { background-color: #8A2BE2; color: #ffffff; }

.item-scroll { white-space: nowrap; padding: 12px 16px; flex: 1; box-sizing: border-box; }
.scroll-item { display: inline-flex; width: 70px; height: 70px; background-color: #F8F9FF; border-radius: 14px; align-items: center; justify-content: center; margin-right: 14px; border: 1px solid #EDEDED; overflow: hidden; transition: transform 0.2s ease; }
.scroll-item:active { transform: scale(0.92); background-color: #F0F0FF; }
.library-img { width: 100%; height: 100%; padding: 6px; box-sizing: border-box; }

.empty-state { flex: 1; display: flex; align-items: center; justify-content: center; color: #999999; font-size: 14px; }
.drag-hint { text-align: center; font-size: 12px; color: #94A3B8; padding-bottom: 4px; }
.arrow-up { color: #8A2BE2; font-weight: bold; }

.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 80px; display: flex; justify-content: space-around; padding-top: 12px; border-top: 1px solid rgba(200,200,200,0.5); z-index: 50; }
.tab-item { display: flex; flex-direction: column; align-items: center; }
.tab-icon { width: 24px; height: 24px; margin-bottom: 4px; }
.tab-text { font-size: 10px; color: #999999; font-weight: 500; }
.tab-item.active .tab-text { color: #8A2BE2; }

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}
.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}
.modal-content {
  width: 80%;
  max-width: 320px;
  border-radius: 24px;
  padding: 24px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  transform: translateY(20px);
  transition: all 0.3s ease;
}
.modal-mask.show .modal-content {
  transform: translateY(0);
}
.modal-header {
  margin-bottom: 20px;
  text-align: center;
}
.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}
.modal-body {
  margin-bottom: 24px;
}
.title-input {
  width: 100%;
  height: 48px;
  background: #F8FAFC;
  border-radius: 12px;
  padding: 0 16px;
  box-sizing: border-box;
  font-size: 15px;
  color: #333;
  border: 1px solid #E2E8F0;
}
.modal-footer {
  display: flex;
  gap: 12px;
}
.modal-btn {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 500;
}
.modal-btn.cancel {
  background: #F1F5F9;
  color: #64748B;
}
.modal-btn.confirm {
  background: linear-gradient(135deg, #8A2BE2, #9370DB);
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(138, 43, 226, 0.3);
}
