page {
  background: #F5F5F7;
  color: #333333;
}

.container {
  padding: 16px;
  padding-bottom: 40px;
}

.glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
}

.hero-section {
  border-radius: 24px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 12px 32px rgba(138, 43, 226, 0.04);
}

.overview-title {
  font-size: 15px;
  font-weight: 700;
  color: #8A2BE2;
  letter-spacing: 1.5px;
  margin-bottom: 20px;
  text-transform: uppercase;
}

.stats-cards {
  display: flex;
  gap: 16px;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20px;
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.02);
}

.stat-num {
  font-size: 36px;
  font-weight: 800;
  color: #3D1F8C;
  margin-bottom: 6px;
  line-height: 1;
}

.stat-label {
  font-size: 13px;
  color: #5E5576;
  font-weight: 500;
}

.section {
  background: #FFFFFF;
  border-radius: 24px;
  padding: 24px;
  margin-bottom: 20px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.02);
}

.section-title {
  font-size: 18px;
  font-weight: 800;
  color: #27173D;
  margin-bottom: 4px;
}

.section-subtitle {
  display: block;
  font-size: 12px;
  color: #94A3B8;
  margin-bottom: 24px;
}

/* Category Row */
.category-row {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  gap: 14px;
}
.category-row:last-child {
  margin-bottom: 0;
}

.cat-label {
  width: 54px;
  font-size: 14px;
  color: #475569;
  font-weight: 500;
}

.progress-track {
  flex: 1;
  height: 10px;
  background: #F1F5F9;
  border-radius: 5px;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #B28DFF, #8A2BE2);
  border-radius: 5px;
  transition: width 0.8s ease-out;
}

.cat-count {
  width: 36px;
  text-align: right;
  font-size: 15px;
  font-weight: 600;
  color: #1E293B;
}

/* Pie Chart */
.pie-container {
  display: flex;
  align-items: center;
  margin-top: 24px;
}

.pie-chart {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  margin-right: 32px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  border: 4px solid #FFFFFF;
}

.pie-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.legend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.legend-swatch {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1px solid #E2E8F0;
  box-shadow: 0 2px 6px rgba(0,0,0,0.05);
}

.legend-count {
  font-size: 14px;
  color: #475569;
  font-weight: 600;
}

/* Top Picks */
.picks-scroll {
  white-space: nowrap;
  width: 100%;
}

.pick-card {
  display: inline-block;
  width: 120px;
  margin-right: 16px;
}

.pick-img-wrap {
  width: 120px;
  height: 120px;
  background: #F8FAFC;
  border-radius: 20px;
  position: relative;
  border: 1px solid #F1F5F9;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.pick-img {
  width: 100px;
  height: 100px;
}

.wear-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(138, 43, 226, 0.9);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  text-align: center;
  padding: 6px 0;
  backdrop-filter: blur(8px);
}

.cpw-badge {
  margin-top: 8px;
  font-size: 11px;
  color: #8A2BE2;
  font-weight: 700;
  text-align: center;
  background: #F3E8FF;
  border-radius: 8px;
  padding: 4px 0;
}
.cpw-badge.empty {
  color: #94A3B8;
  background: #F1F5F9;
}

.dusty-card {
  opacity: 0.85;
}

.dusty-wrap {
  border: 1px solid #FFE4E6;
  background: #FFF1F2;
}

.dusty-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(225, 29, 72, 0.9);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  text-align: center;
  padding: 6px 0;
  backdrop-filter: blur(8px);
}

.loading-state, .empty-state {
  padding: 60px 0;
  text-align: center;
  color: #94A3B8;
  font-size: 15px;
  font-weight: 500;
}
