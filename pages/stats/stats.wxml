<view class="container">
  <view class="hero-section glass">
    <view class="overview-title">数据驱动衣橱</view>
    <view class="stats-cards">
      <view class="stat-card">
        <text class="stat-num">{{userStats.clothesCount}}</text>
        <text class="stat-label">单品总数</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{userStats.outfitCount}}</text>
        <text class="stat-label">搭配总数</text>
      </view>
    </view>
  </view>

  <view wx:if="{{isLoading}}" class="loading-state">
    <text>数据努力加载中...</text>
  </view>

  <block wx:else>
    <view class="section category-section" wx:if="{{categoryStats.length > 0}}">
      <view class="section-title">分类构成</view>
      <text class="section-subtitle">各类单品储备情况</text>
      <view class="category-list">
        <view class="category-row" wx:for="{{categoryStats}}" wx:key="_id">
          <text class="cat-label">{{item._id}}</text>
          <view class="progress-track">
            <view class="progress-bar" style="width: {{(item.count / userStats.clothesCount) * 100}}%"></view>
          </view>
          <text class="cat-count">{{item.count}}</text>
        </view>
      </view>
    </view>

    <view class="section color-section" wx:if="{{colorStats.length > 0}}">
      <view class="section-title">衣橱色彩全景</view>
      <text class="section-subtitle">{{colorInsight}}</text>
      <view class="pie-container">
        <view class="pie-chart" style="background: {{pieChartStyle}}"></view>
        <view class="pie-legend">
          <view class="legend-item" wx:for="{{colorStats}}" wx:key="_id">
            <view class="legend-swatch" style="background-color: {{item._id}}"></view>
            <text class="legend-count">{{item.count}}件</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section top-picks-section" wx:if="{{topPicks.length > 0}}">
      <view class="section-title">殿堂宠儿 Top 5</view>
      <text class="section-subtitle">最高利用率单品，CPW (每次穿着成本) 极低</text>
      <scroll-view class="picks-scroll" scroll-x show-scrollbar="false" enhanced="true">
        <view class="pick-card" wx:for="{{topPicks}}" wx:key="_id">
          <view class="pick-img-wrap">
            <image class="pick-img" mode="aspectFit" src="{{item.clothInfo[0].image_url}}"></image>
            <view class="wear-badge">穿过 {{item.wearCount}} 次</view>
          </view>
          <view class="cpw-badge" wx:if="{{item.cpw > 0}}">CPW ￥{{item.cpw}}</view>
          <view class="cpw-badge empty" wx:else>未记价</view>
        </view>
      </scroll-view>
    </view>

    <view class="section dusty-picks-section" wx:if="{{dustyPicks.length > 0}}">
      <view class="section-title">吃灰重灾区</view>
      <text class="section-subtitle">躺在箱底从未被翻牌，是时候断舍离了？</text>
      <scroll-view class="picks-scroll" scroll-x show-scrollbar="false" enhanced="true">
        <view class="pick-card dusty-card" wx:for="{{dustyPicks}}" wx:key="_id">
          <view class="pick-img-wrap dusty-wrap">
            <image class="pick-img" mode="aspectFit" src="{{item.image_url}}"></image>
            <view class="dusty-badge">闲置 {{item.idleDays}} 天</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{categoryStats.length === 0}}" class="empty-state">
      <text>你的衣橱数据档案还是空的\n快去添加衣服或记录搭配吧~</text>
    </view>
  </block>
</view>
