<view class="container" bindtap="deselectText">
  <view class="preview-shell">
    <view class="preview-stage">
      <view class="canvas-frame">
        <view
          id="previewArea"
          class="canvas-area {{isMulti ? 'multi-mode' : ''}} {{activeDrawerTab === 'text' ? 'text-mode' : ''}}"
          style="background: {{selectedBg.type === 'image' ? 'transparent' : selectedBg.css}}; background-size: {{selectedBg.grid || selectedBg.dots ? '20px 20px' : 'cover'}};"
          catchtap="onCanvasTap"
        >
          <image
            wx:if="{{selectedBg.type === 'image'}}"
            class="bg-image"
            src="{{selectedBg.value}}"
            mode="aspectFill"
          ></image>

          <image
            wx:if="{{!isMulti && look.preview_url}}"
            class="outfit-image"
            src="{{look.preview_url}}"
            mode="aspectFit"
          ></image>

          <view wx:if="{{isMulti}}" class="multi-item-preview">
            <image
              wx:for="{{imageUrls}}"
              wx:key="*this"
              class="multi-item-img"
              src="{{item}}"
              mode="widthFix"
            ></image>
          </view>

          <block wx:for="{{textItems}}" wx:key="id">
            <view
              class="text-item align-{{item.align || 'left'}} {{item.active ? 'active' : ''}} {{editingTextId === item.id && canvasInputFocus ? 'editing-source' : ''}}"
              style="left: {{item.x}}px; top: {{item.y}}px; font-size: {{item.size}}px; color: {{item.color}};"
              catchtouchstart="onTextTouchStart"
              catchtouchmove="onTextTouchMove"
              catchtouchend="onTextTouchEnd"
              catchtap="activateText"
              data-id="{{item.id}}"
            >
              <text class="{{editingTextId === item.id && canvasInputFocus ? 'text-item-ghost' : ''}}">{{item.content}}</text>
              <view
                wx:if="{{item.active && editingTextId !== item.id}}"
                class="delete-btn"
                catchtouchstart="deleteText"
                data-id="{{item.id}}"
              >×</view>
            </view>
          </block>

          <view
            wx:if="{{editingTextIndex > -1 && activeDrawerTab === 'text' && canvasInputFocus}}"
            class="text-item text-editor-overlay active editing align-{{textItems[editingTextIndex].align || 'left'}}"
            style="left: {{textItems[editingTextIndex].x}}px; top: {{textItems[editingTextIndex].y}}px; font-size: {{textItems[editingTextIndex].size}}px; color: {{textItems[editingTextIndex].color}};"
            catchtap="noop"
          >
            <input
              class="canvas-text-input align-{{textItems[editingTextIndex].align || 'left'}}"
              value="{{activeTextDraft}}"
              placeholder="输入文字"
              placeholder-class="canvas-text-placeholder"
              focus="{{canvasInputFocus}}"
              cursor-spacing="16"
              adjust-position="false"
              bindinput="onActiveTextInput"
              bindblur="onCanvasTextBlur"
            />
            <view
              class="delete-btn"
              catchtouchstart="deleteText"
              data-id="{{editingTextId}}"
            >×</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="drawer" catchtap="true">
    <view class="drawer-handle"></view>

    <view class="drawer-topbar">
      <view class="drawer-tabs">
        <view
          class="drawer-tab {{activeDrawerTab === 'background' ? 'active' : ''}}"
          bindtap="switchDrawerTab"
          data-tab="background"
        >背景</view>
        <view
          class="drawer-tab {{activeDrawerTab === 'text' ? 'active' : ''}}"
          bindtap="switchDrawerTab"
          data-tab="text"
        >文字</view>
      </view>
      <button class="drawer-save-btn" catchtap="saveImage">保存</button>
    </view>

    <view wx:if="{{activeDrawerTab === 'background'}}" class="drawer-content">
      <scroll-view class="bg-grid-scroll" scroll-y="true" show-scrollbar="false">
        <view class="bg-grid">
          <view
            wx:for="{{backgrounds}}"
            wx:key="id"
            class="bg-card {{selectedBg.id === item.id ? 'selected' : ''}}"
            catchtap="selectBg"
            data-bg="{{item}}"
          >
            <view
              class="bg-swatch"
              style="background: {{item.type === 'image' ? 'transparent' : item.css}}; background-size: {{item.grid || item.dots ? '20px 20px' : 'cover'}};"
            >
              <image
                wx:if="{{item.type === 'image'}}"
                class="bg-thumb"
                src="{{item.value}}"
                mode="aspectFill"
              ></image>
            </view>
            <text class="bg-label">{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:elif="{{activeDrawerTab === 'text'}}" class="drawer-content">
      <view class="text-editor-card">
        <block wx:if="{{activeTextId}}">
          <view class="setting-card">
            <view class="setting-block">
              <view class="setting-head">
                <text class="setting-title">字号</text>
                <text class="setting-value">{{textItems[activeTextId - 1] ? textItems[activeTextId - 1].size : 24}} px</text>
              </view>
              <slider
                min="12"
                max="64"
                value="{{textItems[activeTextId - 1] ? textItems[activeTextId - 1].size : 24}}"
                activeColor="#8A2BE2"
                backgroundColor="#E7DDF8"
                block-color="#8A2BE2"
                block-size="18"
                bindchange="changeTextSize"
                bindchanging="changeTextSize"
              />
            </view>

            <view class="setting-head">
              <text class="setting-title">颜色</text>
            </view>
            <scroll-view class="color-scroll" scroll-x="true" show-scrollbar="false">
              <view class="color-list">
                <view
                  wx:for="{{textColors}}"
                  wx:key="*this"
                  class="text-color-circle {{textItems[activeTextId - 1] && textItems[activeTextId - 1].color === item ? 'selected' : ''}}"
                  style="background-color: {{item}};"
                  catchtap="changeTextColor"
                  data-color="{{item}}"
                ></view>
              </view>
            </scroll-view>

            <view class="setting-divider"></view>

            <view class="setting-head">
              <text class="setting-title">对齐</text>
            </view>
            <view class="align-row">
              <view
                wx:for="{{textAlignOptions}}"
                wx:key="*this"
                class="align-chip {{textItems[activeTextId - 1] && textItems[activeTextId - 1].align === item ? 'active' : ''}}"
                catchtap="changeTextAlign"
                data-align="{{item}}"
              >
                {{item === 'left' ? '左对齐' : item === 'center' ? '居中' : '右对齐'}}
              </view>
            </view>
          </view>
        </block>

        <view wx:else class="empty-editor">
          <text class="empty-editor-title">点击画布任意位置添加文字</text>
        </view>
      </view>
    </view>
  </view>

  <canvas type="2d" id="exportCanvas" class="export-canvas"></canvas>
</view>
