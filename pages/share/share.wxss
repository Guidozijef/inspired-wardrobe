.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f1ff;
  /* background:
    radial-gradient(circle at top right, rgba(168, 124, 255, 0.25), transparent 24%),
    linear-gradient(180deg, #f5f1ff 0%, #eef3ff 100%); */
}

.preview-shell {
  flex: 1;
  min-height: 0;
  padding: 10px 16px 8px;
  box-sizing: border-box;
}

.preview-stage {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.canvas-frame {
  flex: 1;
  min-height: 0;
  padding: 10px;
  border-radius: 26px;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(16px);
  box-shadow: 0 20px 40px rgba(74, 48, 117, 0.09);
}

.canvas-area {
  width: 100%;
  height: 100%;
  border-radius: 22px;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.56);
  background-position: center;
}

.canvas-area.text-mode {
  cursor: text;
}

.safe-guide {
  position: absolute;
  z-index: 2;
  pointer-events: none;
  opacity: 0.55;
}

.safe-guide-top,
.safe-guide-bottom {
  left: 16px;
  right: 16px;
  height: 1px;
  border-top: 1px dashed rgba(138, 43, 226, 0.28);
}

.safe-guide-top {
  top: 16px;
}

.safe-guide-bottom {
  bottom: 16px;
}

.safe-guide-left,
.safe-guide-right {
  top: 16px;
  bottom: 16px;
  width: 1px;
  border-left: 1px dashed rgba(138, 43, 226, 0.28);
}

.safe-guide-left {
  left: 16px;
}

.safe-guide-right {
  right: 16px;
}

.canvas-area.multi-mode {
  overflow: hidden;
}

.bg-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.outfit-image {
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 1;
}

.multi-item-preview {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18px 0;
}

.multi-item-img {
  width: 94%;
  margin-bottom: 18px;
}

.text-item {
  position: absolute;
  z-index: 10;
  padding: 8px 12px;
  white-space: nowrap;
  font-weight: bold;
  line-height: 1.3;
  text-shadow: 0 1px 2px rgba(0,0,0,0.12);
  box-sizing: border-box;
}

.text-item.align-left {
  transform: translateX(0);
  text-align: left;
}

.text-item.align-center {
  transform: translateX(-50%);
  text-align: center;
}

.text-item.align-right {
  transform: translateX(-100%);
  text-align: right;
}

.text-item.active {
  border: 1px dashed rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.15);
}

.text-item.editing {
  min-width: 120px;
  padding-right: 20px;
}

.canvas-text-input {
  min-width: 120px;
  height: 1.3em;
  padding: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
  font-weight: inherit;
  line-height: 1.3;
  border: none;
  display: block;
}

.canvas-text-input.align-left {
  text-align: left;
}

.canvas-text-input.align-center {
  text-align: center;
}

.canvas-text-input.align-right {
  text-align: right;
}

.canvas-text-placeholder {
  color: rgba(255, 255, 255, 0.75);
}

.delete-btn {
  position: absolute;
  top: -10px;
  right: -10px;
  width: 20px;
  height: 20px;
  background: #ff4d4f;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #ffffff;
  font-size: 14px;
  line-height: 1;
}

.drawer {
  height: 45vh;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(24px);
  border-top-left-radius: 28px;
  border-top-right-radius: 28px;
  padding: 10px 16px calc(16px + env(safe-area-inset-bottom));
  box-shadow: 0 -16px 38px rgba(55, 38, 94, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.drawer-topbar {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}

.drawer-handle {
  width: 42px;
  height: 5px;
  background: #d7cfeb;
  border-radius: 999px;
  margin: 0 auto 12px;
}

.drawer-save-btn {
  flex-shrink: 0;
  min-width: 64px;
  height: 38px;
  padding: 0 14px;
  border-radius: 14px;
  background: linear-gradient(135deg, #8f4df0 0%, #7a37e6 100%);
  color: #ffffff;
  font-size: 14px;
  font-weight: 600;
  line-height: 38px;
  box-shadow: 0 8px 18px rgba(122, 55, 230, 0.22);
}

.drawer-save-btn::after {
  border: none;
}

.drawer-tabs {
  display: flex;
  flex: 1;
  padding: 4px;
  border-radius: 18px;
  background: #f3effc;
}

.drawer-tab {
  flex: 1;
  height: 38px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a6f95;
  font-size: 14px;
  font-weight: 600;
}

.drawer-tab.active {
  background: #ffffff;
  color: #8A2BE2;
  box-shadow: 0 6px 16px rgba(91, 72, 130, 0.1);
}

.drawer-content {
  height: calc(100% - 70px);
  display: flex;
  flex-direction: column;
}

.bg-grid-scroll {
  flex: 1;
  min-height: 0;
}

.bg-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  padding-bottom: 8px;
}

.bg-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.bg-swatch {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 16px;
  overflow: hidden;
  border: 2px solid transparent;
  box-shadow: 0 4px 12px rgba(64, 44, 108, 0.06);
  box-sizing: border-box;
}

.bg-card.selected .bg-swatch {
  border-color: #8A2BE2;
}

.bg-thumb {
  width: 100%;
  height: 100%;
}

.bg-label {
  font-size: 11px;
  color: #5e5576;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.text-editor-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  border-radius: 20px;
  background: #f8f6fc;
  padding: 8px;
}

.setting-card {
  padding: 10px;
  border-radius: 16px;
  background: #ffffff;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.86);
}

.setting-block {
  margin-bottom: 8px;
}

.setting-block:last-child {
  margin-bottom: 0;
}

.setting-divider {
  height: 1px;
  background: rgba(140, 131, 163, 0.12);
  margin: 8px 0;
}

.setting-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}

.setting-title {
  font-size: 14px;
  font-weight: 600;
  color: #27173d;
}

.setting-value {
  font-size: 12px;
  color: #8d84a4;
}

.align-row {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.align-chip {
  flex: 1;
  height: 34px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4effb;
  color: #74698c;
  font-size: 12px;
  font-weight: 600;
}

.align-chip.active {
  background: rgba(138, 43, 226, 0.12);
  color: #8A2BE2;
  box-shadow: inset 0 0 0 1px rgba(138, 43, 226, 0.18);
}

.color-scroll {
  width: 100%;
  white-space: nowrap;
}

.color-list {
  display: inline-flex;
  align-items: center;
  padding: 4px 2px;
}

.text-color-circle {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  margin-right: 10px;
  border: 2px solid #ddd5ee;
  box-sizing: border-box;
  flex-shrink: 0;
}

.text-color-circle.selected {
  border-color: #8A2BE2;
  transform: scale(1.06);
}

.empty-editor {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8px;
}

.empty-editor-title {
  font-size: 15px;
  font-weight: 600;
  color: #8d84a4;
}

.export-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1000px;
  height: 1000px;
}
