.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F2F2F7;
}

.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-left-actions {
  left: 10px;
  display: flex;
  align-items: center;
}

.nav-btn {
  display: flex;
  align-items: center;
  font-size: 16px;
  color: #333;
  padding: 5px 10px;
}

.back-icon {
  font-size: 24px;
  margin-right: 4px;
  margin-top: -2px;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #1c1c1e;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 画布区域 */
.canvas-wrapper {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px;
}

.canvas-area {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
  transition: background-color 0.3s ease;
}

.outfit-image {
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 1;
}

/* 文本叠加元素 */
.text-item {
  position: absolute;
  z-index: 10;
  padding: 8px 12px;
  white-space: nowrap;
  font-weight: bold;
  text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  box-sizing: border-box;
}

.text-item.active {
  border: 1px dashed rgba(255, 255, 255, 0.8);
  background-color: rgba(255, 255, 255, 0.1);
}

.delete-btn {
  position: absolute;
  top: -10px;
  right: -10px;
  width: 20px;
  height: 20px;
  background-color: #ff3b30;
  color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  font-weight: bold;
  border: 2px solid white;
}

/* 底部工具面板 */
.tools-panel {
  background: white;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  padding: 24px;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  box-shadow: 0 -4px 16px rgba(0,0,0,0.05);
}

.glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.color-scroll {
  width: 100%;
  white-space: nowrap;
}

.color-list {
  display: inline-flex;
  padding: 4px;
}

.color-card {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  margin-right: 12px;
  border: 2px solid transparent;
  transition: transform 0.2s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.color-card.selected {
  transform: scale(1.1);
  border: 2px solid #8A2BE2;
}

/* 文字设置样式 */
.tool-row {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.tool-label {
  font-size: 14px;
  color: #666;
  width: 40px;
  flex-shrink: 0;
}

.tool-slider {
  flex: 1;
  margin: 0 10px;
}

.text-color-circle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  margin-right: 12px;
  border: 2px solid #e0e0e0;
  flex-shrink: 0;
  box-sizing: border-box;
  transition: transform 0.2s;
}

.text-color-circle.selected {
  transform: scale(1.2);
  border-color: #8A2BE2;
}

.divider {
  height: 1px;
  background-color: #f0f0f0;
  margin: 20px 0;
}

.text-tool {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
}

.text-input {
  flex: 1;
  background: #f5f5f7;
  height: 44px;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 15px;
}

.add-text-btn {
  margin: 0;
  background: #f0e6ff;
  color: #8A2BE2;
  font-size: 14px;
  font-weight: 600;
  padding: 0 16px;
  height: 44px;
  line-height: +44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-text-btn::after {
  display: none;
}

.bottom-actions {
  display: flex;
  gap: 16px;
}

.action-btn {
  flex: 1;
  height: 50px;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  justify-content: center;
  align-items: center;
}

.action-btn::after {
  display: none;
}

.cancel-btn {
  background: #f5f5f7;
  color: #666;
}

.primary-btn {
  background: linear-gradient(135deg, #8A2BE2, #B983FF);
  color: white;
  box-shadow: 0 4px 12px rgba(138, 43, 226, 0.3);
}

.export-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1000px;
  height: 1000px;
}
