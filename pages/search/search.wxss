/* Container & Search Header */
.container { height: 100vh; display: flex; flex-direction: column; background: linear-gradient(180deg, #faf8ff 0%, #f3f0fc 100%); overflow: hidden; }
.search-header { display: flex; align-items: flex-end; padding: 0 20px; box-sizing: border-box; position: relative; z-index: 10; padding-bottom: 12px; }
.glass { background: rgba(250, 248, 255, 0.94); backdrop-filter: blur(24px); border-bottom: 1px solid rgba(124, 58, 237, 0.06); }
.search-bar { flex: 1; height: 36px; background-color: #ffffff; border-radius: 18px; display: flex; align-items: center; padding: 0 16px; margin-right: 16px; box-shadow: 0 2px 14px rgba(100, 60, 200, 0.06); }
.search-icon { width: 16px; height: 16px; margin-right: 8px; opacity: 0.6; }
.search-input { flex: 1; font-size: 14px; color: #1C1033; }
.cancel-btn { font-size: 15px; color: #7C3AED; font-weight: 600; padding-bottom: 8px; }

/* Scroll Content */
.search-content { flex: 1; padding: 24px 20px; box-sizing: border-box; }
.section { margin-bottom: 32px; }
.section-title { display: flex; justify-content: space-between; align-items: center; font-size: 15px; font-weight: 700; color: #1C1033; margin-bottom: 16px; }
.delete-icon { width: 18px; height: 18px; opacity: 0.6; }
.tags { display: flex; flex-wrap: wrap; gap: 12px; }
.tag { padding: 6px 16px; background-color: #ffffff; color: #6B7280; font-size: 13px; font-weight: 500; border-radius: 16px; border: 1px solid rgba(124, 58, 237, 0.08); box-shadow: 0 2px 8px rgba(100, 60, 200, 0.04); }
.tag.hot { background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%); color: #7C3AED; border: none; }

/* Grid Styles (Copied from Wardrobe) */
.grid { display: flex; flex-wrap: wrap; justify-content: space-between; padding-bottom: 40px; }
.grid-item { width: 48.5%; background: #ffffff; border-radius: 20px; padding: 10px; margin-bottom: 16px; box-shadow: 0 4px 20px rgba(100, 60, 200, 0.08); border: 1px solid rgba(124, 58, 237, 0.06); box-sizing: border-box; }
.item-img-bg { background: linear-gradient(145deg, #f5f0ff 0%, #e9e2f9 100%); height: 175px; border-radius: 14px; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
.main-img { width: 100%; height: 100%; padding: 6px; box-sizing: border-box; }
.pre-load { opacity: 0; }
.fade-in { animation: trueFadeIn 0.5s ease-out forwards; }
@keyframes trueFadeIn { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }
.item-info { padding: 10px 4px 2px; }
.item-header { display: flex; justify-content: space-between; align-items: flex-start; }
.item-title { font-size: 14px; font-weight: 700; color: #1C1033; line-height: 1.2; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
.season-list { display: flex; gap: 2px; margin-left: 4px; padding-top: 1px; }
.season-icon { font-size: 12px; opacity: 0.85; }
.item-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
.item-desc { font-size: 12px; color: #9CA3AF; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.custom-tag { background: linear-gradient(135deg, #7C3AED, #9F5FF0); padding: 2px 8px; border-radius: 8px; font-size: 10px; color: #ffffff; font-weight: 600; margin-left: 6px; white-space: nowrap; }

/* Status */
.loading-status { text-align: center; padding: 24px 0; color: #9CA3AF; font-size: 13px; width: 100%; letter-spacing: 0.3px; }

/* Empty State */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 80px; width: 100%; }
.empty-icon { width: 64px; height: 64px; opacity: 0.7; margin-bottom: 20px; }
.empty-title { font-size: 18px; font-weight: 700; color: #1C1033; margin-bottom: 8px; }
.empty-tips { font-size: 14px; color: #9CA3AF; }
