.container { 
  height: 100vh; 
  background: linear-gradient(180deg, #faf8ff 0%, #f3f0fc 100%);
  position: relative; 
  overflow: hidden; 
  display: flex; 
  flex-direction: column; 
}

.glass { 
  background: rgba(255, 255, 255, 0.6); 
  backdrop-filter: blur(24px); 
  border: 1px solid rgba(255, 255, 255, 0.8); 
  box-shadow: 0 8px 32px rgba(124, 58, 237, 0.04); 
}

.main-content { flex: 1; display: flex; flex-direction: column; position: relative; z-index: 1; box-sizing: border-box; padding-bottom: 94px; justify-content: space-between; }

.header { padding: 10px 24px 0; flex-shrink: 0; }
.greeting { font-size: 24px; font-weight: 800; color: #2D1B4E; margin-bottom: 6px; letter-spacing: 0.5px; }
.date { font-size: 12px; color: #7a6f95; font-weight: 500; letter-spacing: 0.5px; }

/* Weather Card */
.weather-card { margin: 0 24px; padding: 22px 20px; border-radius: 24px; flex-shrink: 0; }
.weather-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
.weather-info { display: flex; align-items: baseline; }
.weather-icon { font-size: 36px; margin-right: 12px; }
.weather-temp { font-size: 36px; font-weight: 800; color: #2D1B4E; margin-right: 8px; font-family: 'DIN Alternate', sans-serif; }
.weather-desc { font-size: 15px; color: #7a6f95; font-weight: 600; }
.weather-location { display: flex; align-items: center; background: rgba(124, 58, 237, 0.08); padding: 6px 12px; border-radius: 20px; }
.location-icon { width: 14px; height: 14px; margin-right: 4px; }
.weather-location text { font-size: 11px; color: #7C3AED; font-weight: 700; }
.weather-advice { background: rgba(124, 58, 237, 0.04); padding: 12px 16px; border-radius: 16px; display: flex; align-items: center; }
.weather-advice text { font-size: 13px; color: #7a6f95; font-weight: 500; }

/* Actions */
.actions-section { margin: 0 24px; flex-shrink: 0; }
.action-btn { border-radius: 22px; display: flex; align-items: center; position: relative; overflow: hidden; }
.action-btn.primary { padding: 20px; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.9); margin-bottom: 16px; box-shadow: 0 12px 32px rgba(124, 58, 237, 0.08); }
.action-icon-bg { width: 48px; height: 48px; border-radius: 16px; background: rgba(124, 58, 237, 0.06); border: 1px solid rgba(124, 58, 237, 0.1); display: flex; align-items: center; justify-content: center; margin-right: 16px; }
.action-icon { width: 28px; height: 28px; }
.action-texts { flex: 1; display: flex; flex-direction: column; }
.action-title { font-size: 17px; font-weight: 800; color: #2D1B4E; margin-bottom: 4px; }
.action-desc { font-size: 11px; color: #7a6f95; font-weight: 500; }
.action-arrow { font-size: 18px; color: #C8B5E8; font-weight: 800; }

.action-row { display: flex; gap: 16px; }
.action-btn.secondary { flex: 1; padding: 16px; flex-direction: column; justify-content: center; }
.action-icon-small { width: 28px; height: 28px; margin-bottom: 10px; opacity: 0.9; }
.action-title-small { font-size: 14px; font-weight: 600; color: #2D1B4E; }

/* Recommend Section */
.recommend-section { margin: 0 24px 10px; flex-shrink: 0; }
.section-title { display: flex; align-items: baseline; margin-bottom: 16px; flex-shrink: 0; }
.section-title text:first-child { font-size: 18px; font-weight: 800; color: #2D1B4E; margin-right: 8px; }
.section-subtitle { font-size: 11px; color: #C8B5E8; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }

.picks-container { 
  display: flex; 
  gap: 16px; 
  overflow-x: auto; 
  overflow-y: hidden; 
  margin-right: -24px; 
  padding-right: 24px; 
  align-items: flex-start;
}
.picks-container::-webkit-scrollbar { display: none; }
.pick-item { 
  min-width: 130px; 
  width: 130px; 
  padding: 12px; 
  border-radius: 20px; 
  display: flex; 
  flex-direction: column; 
  box-sizing: border-box; 
}
.pick-img-wrapper { 
  width: 100%; 
  height: 120px; 
  border-radius: 14px; 
  background: rgba(255,255,255,0.4); 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  margin-bottom: 12px; 
  overflow: hidden; 
}
.pick-img { width: 85%; height: 85%; }
.pick-title { font-size: 13px; font-weight: 600; color: #2D1B4E; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex-shrink: 0; }

.empty-picks { padding: 30px 20px; border-radius: 24px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.empty-picks-icon { width: 44px; height: 44px; margin-bottom: 12px; opacity: 0.8; }
.empty-picks text { font-size: 13px; color: #7a6f95; margin-bottom: 16px; }
.empty-add-btn { background: #2D1B4E; color: #ffffff; font-size: 13px; font-weight: 600; padding: 8px 20px; border-radius: 20px; }

/* Tab Bar */
.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 84px; display: flex; justify-content: space-around; padding-bottom: env(safe-area-inset-bottom); border-radius: 30px 30px 0 0; z-index: 100; border-top: 1px solid rgba(255, 255, 255, 0.4); }
.tab-item { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 8px; flex: 1; }
.tab-icon { width: 24px; height: 24px; margin-bottom: 4px; opacity: 0.6; transition: all 0.3s ease; }
.tab-text { font-size: 10px; color: #9CA3AF; transition: all 0.3s ease; }
.tab-item.active .tab-icon { opacity: 1; transform: translateY(-2px); }
.tab-item.active .tab-text { color: #7C3AED; font-weight: 600; }
